repeat {
    // Handle player location description
    if (status:moved) {
        describe(here);
        var youSee = true;
        for (var optr : here) {
            if (youSee) {
                say("");
                youSee = false;
            }
            describe(optr);
        }
    }
}
repeat {
    // Handle player input
    input();                    // Get and parse player's command
    //say("arg1 is $", arg1);
    //say("arg2 is $", arg2);
    //say("status is $", status);
    if (status < 0) {           // Can't find 2nd or 1st command word in the vocabulary
        quip("Pardon?");        // Command parse failure -- abort the main loop
    }
    if (key("quit")) {    // If the word QUIT occurs in the command, exit the game
        say("As you wish.");
        stop();
    }

    playerPower--;
    here(arg1);             // Execute code, if any, associated with this location
    arg1(arg2);             // Execute action verb, if any
    ref objVerb = null;
    for (ref optr : inhand) {
        for (ref vptr : optr) {
            if (strcmp(vptr, arg1) == 0) {
                if (optr == arg2) {
                    optr(arg1);     // Found specific "verb object" match
                } else if (objVerb != null) {
                    quip("Quitting in else if");
//                    bailOut();  // We have a duplicate
                } else  {
                    objVerb = optr;
                }
            }
        }
    }
    if (objVerb != null) {
        objVerb(arg1);
    }
    playerPower++;

    quip("quitting now");
//    bailOut();         // Command not handled - report an error
}

    // Deliver invalid command message
