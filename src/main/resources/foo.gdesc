text noDirection
    """
    You can't tell directions here.
    Try Up, Down, Left, Right, Forward, Backward""";

fragment you_do
    "You #";

text brightFlashAnd
    """
    There's no place like home.

    There is a bright flash and ...""";

action "inventory" {
    say("In inventory");
    break repeat;              // Command fully handled, so terminate the REPEAT loop
}
