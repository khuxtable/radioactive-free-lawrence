object axe
    "small axe"
    "There is a small axe here."
{
    action "swing" { useweapon(this, false, 1, 40, 100, 0); }
    action "throw" { useweapon(this, true, 1, 25, 75, 0); }
}
object hatchet
    "small hatchet"
    "There is a small hatchet here."
{
    action "swing" { useweapon(this, false, 1, 40, 100, 0); }
    action "throw" { useweapon(this, true, 1, 25, 75, 0); }
}
object banana
    "slightly brown banana"
    "There is a slightly brown banana here."
{
    action "eat" { consume(false, 1, -2, -10, "That tasted HORRIBLE; what a bellyache!", "slightly brown banana peel"); }
}
object book
    "book"
    "There is a book here."
{
    action "open" { quip("The pages are fused together."); }
    action "read" { quip("The book is closed. The cover reads \"How to Survive a Nuclear War.\""); }
}
object box
    "box"
    "There is a locked box here."
{
    action "throw" { useweapon(this, true, 1, 50, 25, 0); }
    action "open" {
        alterpower(0, 100, 2000, 2000,
        "Congratulations! You have found the treasure.\nYou are hereby awarded with 200% life force.",
        "The interior is filled with meters and other strange appurtenances,\nbut nothing seems to happen.");
    }
}
object chain
    "chain"
    "There is a length of chain here."
{
    action "belt" { useweapon(this, false, 3, 50, 75, 0); }
}
object coke
    "coke can"
    "There is a can of coke here."
{
    action "drink" { consume(this, false, 1, 2, 50, "Things go better with coke, but only a little better.", "an empty coke can"); }
    action "throw" { useweapon(this, true, 1, 50, 25, 0); }
}
object dagger
    "dagger"
    "There is a dagger here."
{
    action "swing" { useweapon(this, false, 1, 45, 50, 0); }
    action "stab" { useweapon(this, false, 1, 45, 50, 0); }
    action "throw" { useweapon(this, true, 1, 20, 50, 0); }
}
object glove
    "silk glove"
    "There is a silk glove here."
{
    action "pickpocket" { stealSomething(50, 40); }
}
object grenade
    "grenade"
    "There is a grenade here."
    "A grenade, which does not actually appear anywhere"
{
    action "throw" { useweapon(this, true, 9, 50, 200, 0); }
    action "hurl" { useweapon(this, true, 9, 50, 200, 0); }
}
object gun
    "gun"
    "There is a gun here."
{
    action "shoot" { useweapon(this, false, 1, 30, 200, 0); }
    action "fire" { useweapon(this, false, 1, 30, 200, 0); }
}
object hole
    "small hole"
    "There is a small hole here."
{
    action "open" {
        move(pu_soap_film, "The hole opens and sucks you in.");
    }
    action "take" {
        move(pu_soap_film, "The hole opens and sucks you in...Sucker!");
    }
}
object meter
    "life-force meter"
    "There is a life-force meter here. Cannot be dropped."
{
    action "read" { quip("You have $ life force.", playerPower++); }
}
