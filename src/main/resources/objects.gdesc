object udk
    "UDK"
    "There is a faded UDK here."
    "A faded copy of the university newspaper, the \"University Daily Kansan\""
{
    action "read" {
        sayrandom(
        10, "The UDK says, 'US declares war on Rusia'.",
        5, "The UDK says, 'Radiation victims should go to the Reactor Center'.",
        20, "The UDK says, 'KSU 50; KU 36'.",
        10, "Too faded to read, but your hands are now covered with printer's ink.",
        5, "'Rusia drops bomb; Chancellor says grounds WILL be watered.'",
        15, "'Lawrence destroyed; Homecoming ruined.'",
        100, "The hot wind blurs your eyes, preventing you from reading it."
        );
    }
}
object zapgun
    "zapgun"
    "There is a toy zapgun here."
{
    action "terminate" { stop(); }
    action "warp" { warp(true, 50, 0); }
    action "zap" { warp(false, 25, 0); }
}
